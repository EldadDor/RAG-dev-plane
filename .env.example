APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---- Vector store selection: qdrant | postgres ----
VECTOR_STORE=qdrant

# ---- Qdrant (local dev default) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=developer_docs

# ---- PostgreSQL + pgvector (Azure deployment) ----
# PG_HOST=<server>.postgres.database.azure.com
# PG_PORT=5432
# PG_DATABASE=ragdb
# PG_USER=<pg-user-or-entra-upn>
# PG_PASSWORD=
# PG_SSLMODE=require
# PG_USE_ENTRA=false
# PG_TABLE=document_chunks
# PG_VECTOR_DIM=1536

# ---- Chat provider: openai_compatible | azure_openai ----
CHAT_PROVIDER=openai_compatible
CHAT_BASE_URL=http://10.100.102.12:8080/v1
CHAT_API_KEY=dummy
CHAT_MODEL=qwen2.5:7b-instruct-q4_K_M

# ---- Embedding provider: ollama | azure_openai ----
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=mxbai-embed-large

# ---- Azure OpenAI (shared by chat + embeddings when using azure_openai) ----
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_USE_ENTRA=false

# ---- RAG tuning ----
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RERANK_ENABLED=false
