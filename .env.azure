APP_ENV=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---- Vector store ----
VECTOR_STORE=postgres

# ---- PostgreSQL + pgvector ----
PG_HOST=<server>.postgres.database.azure.com
PG_PORT=5432
PG_DATABASE=ragdb
PG_USER=<entra-upn-or-pg-admin>
PG_PASSWORD=                    # leave empty when PG_USE_ENTRA=true
PG_SSLMODE=require
PG_USE_ENTRA=true               # true = Managed Identity / az login; false = PG_PASSWORD
PG_TABLE=document_chunks
PG_VECTOR_DIM=1536              # MUST match the embedding model dimensions

# ---- Chat: Azure OpenAI ----
CHAT_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_USE_ENTRA=true     # true = Managed Identity / az login; false = CHAT_API_KEY
CHAT_API_KEY=                   # only needed if AZURE_OPENAI_USE_ENTRA=false
CHAT_MODEL=gpt-4o-mini          # = Azure deployment name (not the base model name)

# ---- Embeddings: Azure OpenAI ----
EMBEDDING_PROVIDER=azure_openai
EMBEDDING_MODEL=text-embedding-3-small   # = Azure deployment name

# ---- RAG tuning ----
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RERANK_ENABLED=false
