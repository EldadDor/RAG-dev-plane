APP_ENV=local
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000

# ---- Vector store selection: postgres | qdrant ----
# Aligned with RAG_Embabel-AI local profile (PostgreSQL + pgvector).
VECTOR_STORE=postgres

# ---- PostgreSQL + pgvector (matches RAG_Embabel-AI local profile) ----
# Points to the laptop Postgres instance where the Java schema already exists.
# For docker-compose local setup, change PG_HOST to: postgres-pgvector
PG_HOST=10.100.102.12
PG_PORT=5432
PG_DATABASE=ragdb
PG_USER=rag_app
PG_PASSWORD=rag_app_password
PG_SSLMODE=disable
PG_USE_ENTRA=false
PG_SCHEMA=rag
PG_TABLE=document_chunks
PG_VECTOR_DIM=768

# ---- Qdrant (local dev alternative) ----
# QDRANT_URL=http://10.100.102.12:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=developer_docs

# ---- Chat provider ----
CHAT_PROVIDER=openai_compatible
CHAT_BASE_URL=http://localhost:11434/v1
CHAT_API_KEY=dummy
CHAT_MODEL=llama3.2:3b

# ---- Embedding provider (matches RAG_Embabel-AI local profile) ----
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text

TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RERANK_ENABLED=false
